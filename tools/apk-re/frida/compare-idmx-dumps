#!/usr/bin/env python3
"""Summarize native IDMX before/after Frida dump pairs."""

from __future__ import annotations

import argparse
from collections import defaultdict
from pathlib import Path
import re

ANNEX_B_LONG_START_CODE = b"\x00\x00\x00\x01"
ANNEX_B_SHORT_START_CODE = b"\x00\x00\x01"
PAIR_LABELS = (
    ("idmx-aes-frame-before", "idmx-aes-frame-after"),
    ("idmx-aes-frame-com-before", "idmx-aes-frame-com-after"),
    ("idmx-process-encrypt-before", "idmx-process-encrypt-after"),
    ("playctrl-idmx-aes-frame-before", "playctrl-idmx-aes-frame-after"),
    ("playctrl-idmx-aes-frame-com-before", "playctrl-idmx-aes-frame-com-after"),
    ("playctrl-idmx-process-encrypt-before", "playctrl-idmx-process-encrypt-after"),
)
DUMP_RE = re.compile(r"^(?P<ts>\d+)-(?P<seq>\d+)-(?P<label>.+)-(?P<size>\d+)\.bin$")


def dump_key(path: Path) -> tuple[str, int] | None:
    match = DUMP_RE.match(path.name)
    if not match:
        return None
    return (match.group("ts"), int(match.group("seq")))


def dump_label(path: Path) -> str | None:
    name = path.name
    labels = sorted(
        (label for pair in PAIR_LABELS for label in pair),
        key=len,
        reverse=True,
    )
    for label in labels:
        if label in name:
            return label
    return None


def first_diff(a: bytes, b: bytes) -> int | None:
    for idx, (left, right) in enumerate(zip(a, b, strict=False)):
        if left != right:
            return idx
    if len(a) != len(b):
        return min(len(a), len(b))
    return None


def changed_ranges(a: bytes, b: bytes, *, limit: int = 8) -> list[tuple[int, int]]:
    ranges: list[tuple[int, int]] = []
    start: int | None = None
    max_len = max(len(a), len(b))
    for idx in range(max_len):
        left = a[idx] if idx < len(a) else None
        right = b[idx] if idx < len(b) else None
        if left != right and start is None:
            start = idx
        elif left == right and start is not None:
            ranges.append((start, idx))
            start = None
            if len(ranges) >= limit:
                return ranges
    if start is not None:
        ranges.append((start, max_len))
    return ranges


def nal_types(data: bytes) -> dict[int, int]:
    counts: dict[int, int] = defaultdict(int)
    pos = 0
    while pos < len(data) - 5:
        sc_len = 0
        if data[pos : pos + 4] == ANNEX_B_LONG_START_CODE:
            sc_len = 4
        elif data[pos : pos + 3] == ANNEX_B_SHORT_START_CODE:
            sc_len = 3
        if sc_len:
            header = pos + sc_len
            if header + 1 < len(data):
                counts[(data[header] >> 1) & 0x3F] += 1
            pos += sc_len
        else:
            pos += 1
    return dict(sorted(counts.items()))


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("dump_dir", type=Path)
    args = parser.parse_args()

    files_by_label: dict[str, list[Path]] = defaultdict(list)
    for path in sorted(args.dump_dir.rglob("*.bin")):
        label = dump_label(path)
        if label:
            files_by_label[label].append(path)

    found = False
    for before_label, after_label in PAIR_LABELS:
        afters = {
            (path.parent, dump_key(path)): path
            for path in files_by_label.get(after_label, [])
            if dump_key(path) is not None
        }
        pair_index = 0
        for before_path in files_by_label.get(before_label, []):
            before_key = dump_key(before_path)
            if before_key is None:
                continue
            before_ts, before_seq = before_key
            after_path = afters.get((before_path.parent, (before_ts, before_seq + 1)))
            if after_path is None:
                continue
            pair_index += 1
            before = before_path.read_bytes()
            after = after_path.read_bytes()
            diff = first_diff(before, after)
            found = True
            print(f"{before_label} pair {pair_index}")
            print(f"  before: {before_path}")
            print(f"  after:  {after_path}")
            print(f"  sizes:  {len(before)} -> {len(after)}")
            print(f"  first_diff: {diff}")
            print(f"  changed_ranges: {changed_ranges(before, after)}")
            print(f"  before_nal_types: {nal_types(before)}")
            print(f"  after_nal_types:  {nal_types(after)}")

    if not found:
        print(f"No IDMX before/after dump pairs found under {args.dump_dir}")
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
