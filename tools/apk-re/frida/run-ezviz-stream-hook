#!/usr/bin/env bash
set -euo pipefail

package="${1:-com.ezviz}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v frida >/dev/null 2>&1; then
  echo "frida not found on PATH" >&2
  exit 127
fi

target_args=()
if [[ -n "${EZVIZ_FRIDA_HOST:-}" ]]; then
  target_args=(-H "$EZVIZ_FRIDA_HOST")
elif [[ -n "${EZVIZ_FRIDA_DEVICE:-}" ]]; then
  target_args=(-D "$EZVIZ_FRIDA_DEVICE")
else
  target_args=(-U)
fi

exec frida "${target_args[@]}" -f "$package" -l "$script_dir/ezviz-stream-transform-hook.js"
